# Slack 앱의 Client ID입니다. OAuth 설정을 확인할 때 사용합니다.
SLACK_CLIENT_ID=
# Slack 앱의 Client Secret입니다. OAuth 관련 검증에 사용하므로 실제 값은 공개하지 않습니다.
SLACK_CLIENT_SECRET=
# Slack에서 보낸 요청이 진짜인지 HMAC 서명으로 검증할 때 사용합니다.
SLACK_SIGNING_SECRET=
# Slack 구형 verification token입니다. 새 요청 검증은 signing secret을 우선 사용합니다.
SLACK_VERIFICATION_TOKEN=
# Slack Web API로 메시지를 보낼 때 사용하는 Bot User OAuth Token입니다.
SLACK_BOT_TOKEN=
# 이 샘플 봇이 응답할 slash command 목록입니다. 쉼표로 구분합니다.
SLACK_ALLOWED_COMMANDS=/팝팡,/poppang,/poppangbot
