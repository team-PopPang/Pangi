# Slack에서 보낸 요청이 진짜인지 HMAC 서명으로 검증할 때 사용합니다.
SLACK_SIGNING_SECRET=dummy-local-signing-secret
# Slack Web API로 thread 응답과 reaction을 보낼 때 사용하는 Bot User OAuth Token입니다.
SLACK_BOT_TOKEN=dummy-local-bot-token
# 팡이 요청을 허용할 Slack user id 목록입니다. 쉼표로 구분하며, 로컬 테스트에서는 *를 사용할 수 있습니다.
SLACK_ALLOWED_USER_IDS=U_LOCAL
# 팡이 요청을 허용할 Slack channel id 목록입니다. 쉼표로 구분하며, 로컬 테스트에서는 *를 사용할 수 있습니다.
SLACK_ALLOWED_CHANNEL_IDS=C_LOCAL
# job별 read-only worktree를 생성할 루트 디렉터리입니다.
PANGI_WORKTREE_ROOT=/absolute/path/to/pangi/.data/worktrees
# 팡이가 자동 탐색할 원본 source repo 루트 디렉터리입니다.
PANGI_SOURCE_REPO_ROOT=/absolute/path/to/pangi/repos
# read-only 분석 worktree를 만들 때 먼저 시도할 기준 branch입니다.
PANGI_DEFAULT_BASE_BRANCH=develop
# repo 분석 job 하나가 실행될 수 있는 최대 시간(초)입니다.
PANGI_JOB_TIMEOUT_SECONDS=600
# repo를 읽지 않는 일반 대화 Codex 호출의 최대 시간(초)입니다.
PANGI_CHAT_TIMEOUT_SECONDS=120
# 일반 대화 Codex 호출을 실행할 작업 디렉터리입니다. 비우면 worktree root 아래 기본 경로를 사용합니다.
PANGI_CHAT_WORKSPACE_ROOT=
# Notion OAuth callback 등에 사용할 외부 공개 서버 URL입니다. 비우면 요청 host 기준으로 만듭니다.
PANGI_PUBLIC_BASE_URL=
# repo를 읽지 않는 일반 대화 응답에 사용할 Codex 모델입니다.
PANGI_CHAT_MODEL=gpt-5.4-mini
# 일반 대화 응답에 사용할 Codex reasoning effort입니다.
PANGI_CHAT_REASONING_EFFORT=low
# 입력 가드레일 이후 애매한 요청을 라우팅하는 orchestrator용 Codex 모델입니다.
PANGI_ORCHESTRATOR_MODEL=gpt-5.4-mini
# orchestrator Codex 호출에 사용할 reasoning effort입니다.
PANGI_ORCHESTRATOR_REASONING_EFFORT=low
# orchestrator Codex 호출의 최대 시간(초)입니다.
PANGI_ORCHESTRATOR_TIMEOUT_SECONDS=20
# read-only worktree에서 실제 repo 코드를 읽는 분석용 Codex 모델입니다.
PANGI_ANALYSIS_MODEL=gpt-5.5
# repo 분석 Codex 호출에 사용할 reasoning effort입니다.
PANGI_ANALYSIS_REASONING_EFFORT=high
# Notion context provider 사용 여부입니다. 1이면 Notion 읽기 흐름을 활성화합니다.
PANGI_NOTION_ENABLED=0
# 공식 Notion MCP Streamable HTTP endpoint입니다.
PANGI_NOTION_MCP_URL=https://mcp.notion.com/mcp
# 팡이가 읽을 수 있는 Notion page id allowlist입니다. 쉼표로 구분합니다.
PANGI_NOTION_ALLOWED_PAGE_IDS=
# 팡이가 읽을 수 있는 Notion database id allowlist입니다. 쉼표로 구분합니다.
PANGI_NOTION_ALLOWED_DATABASE_IDS=
# Codex prompt에 붙일 Notion context 최대 길이(문자 수)입니다.
PANGI_NOTION_CONTEXT_MAX_CHARS=6000
# Notion context 조회의 최대 시간(초)입니다.
PANGI_NOTION_TIMEOUT_SECONDS=20
# Notion OAuth token store 파일 경로입니다. 비우면 worktree root 아래 기본 경로를 사용합니다.
PANGI_NOTION_TOKEN_STORE_PATH=
# Notion write 기능 예약 설정입니다. MVP에서는 0으로 두고 쓰기 요청을 지원하지 않습니다.
PANGI_NOTION_WRITE_ENABLED=0
# Git MCP context provider 사용 여부입니다. 1이면 GitHub/Git 맥락 읽기 흐름을 활성화합니다.
PANGI_GIT_MCP_ENABLED=0
# Git MCP Streamable HTTP endpoint입니다.
PANGI_GIT_MCP_URL=https://api.githubcopilot.com/mcp/
# Git MCP 인증 token입니다. 실제 값은 .env 또는 배포 환경에만 저장합니다.
PANGI_GIT_MCP_TOKEN=
# repo catalog를 조회할 GitHub organization 이름입니다.
PANGI_GIT_MCP_ORG=team-PopPang
# Codex prompt에 붙일 Git context 최대 길이(문자 수)입니다.
PANGI_GIT_MCP_CONTEXT_MAX_CHARS=6000
# Git MCP context 조회의 최대 시간(초)입니다.
PANGI_GIT_MCP_TIMEOUT_SECONDS=20
# Git write 기능 예약 설정입니다. MVP에서는 0으로 두고 쓰기 요청을 지원하지 않습니다.
PANGI_GIT_MCP_WRITE_ENABLED=0
# Git MCP org repo가 로컬에 없을 때 clone할 URL 템플릿입니다. {org}, {repo}를 사용할 수 있습니다.
PANGI_GIT_CLONE_URL_TEMPLATE=https://github.com/{org}/{repo}.git
# 관리자 페이지 활성화 여부입니다. 1이면 /pangi-admin 페이지를 엽니다.
PANGI_ENABLE_ADMIN_PAGES=0
# 관리자 페이지 로그인 비밀번호입니다. 관리자 페이지를 켤 때만 필요합니다.
PANGI_ADMIN_PASSWORD=
